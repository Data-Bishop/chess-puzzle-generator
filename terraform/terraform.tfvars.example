# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit real values.

aws_region        = "eu-north-1"
project_name      = "chess-puzzle-generator"
ec2_instance_type = "t3.small"

# Must be globally unique across all AWS accounts
s3_bucket_name    = "chess-puzzle-generator-games-238845559191"

# Must match LAMBDA_SECRET in your EC2 .env file
lambda_secret     = "<same value as LAMBDA_SECRET in .env>"
