# Database Configuration
POSTGRES_USER=databishop
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=chess_puzzles
DATABASE_URL=postgresql://databishop:change_me_in_production@postgres:5432/chess_puzzles

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development

# Chess.com API
CHESS_COM_API_BASE_URL=https://api.chess.com/pub

# Worker mode: "local" uses Redis queue, "lambda" triggers AWS Lambda
WORKER_MODE=local

# Shared secret for Lambda → EC2 callbacks — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Must match the lambda_secret variable in terraform/terraform.tfvars
LAMBDA_SECRET=change_me

# AWS / Lambda configuration (required when WORKER_MODE=lambda)
# AWS_REGION=eu-north-1
# LAMBDA_ETL_ARN=            # Filled by Terraform output: lambda_etl_arn
# Also attach the IAM instance profile (ec2_instance_profile_name output) to the EC2 instance
